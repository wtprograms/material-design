{
  "name": "@wtprograms/material-web",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rimraf dist",
    "build:tsc": "tsc",
    "build:scss": "sass ./src/lib",
    "build:styles": "sass ./src/styles/styles.scss ./dist/styles.css && node -e \"const fs = require('fs-extra'); fs.copy('./src/styles', './dist/styles')\"",
    "build:css-ts": "node ./tools/css-to-ts.js ./src/lib",
    "build": "npm run clean && npm run index && npm run build:scss && npm run build:styles && npm run build:css-ts && npm run build:tsc",
    "index": "node indexer",
    "lint": "eslint . --ext .ts",
    "watch": "npm run index && npm run build:styles && concurrently -k -p \"[{name}]\" -n \"tsc,scss\" -c \"bgBlue.bold,bgMagenta.bold,bgGreen.bold\" \"npm:build:tsc -- --watch --preserveWatchOutput\" \"npm:build:scss -- --watch\" \"npm:build:css-ts -- -w\""
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "fs-extra": "^11.2.0",
    "rimraf": "^5.0.7",
    "sass": "^1.72.0",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.5",
    "lit": "^3.1.2",
    "tslib": "^2.6.2"
  }
}
